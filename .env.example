# LLM API Configuration (supports any OpenAI-compatible provider)
# Important: use the provider root URL, not the full `/chat/completions` endpoint.
LLM_API_KEY=changeme
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.4
UNIVERRA_LLM_RPM=30
UNIVERRA_SIM_SEMAPHORE=1
UNIVERRA_MAX_ACTIVE_AGENTS=2
FLASK_DEBUG=False

# ===== User Auth + MongoDB History =====
# Keep real credentials only in your local .env or deployment secret manager.
MONGODB_URI=changeme
MONGODB_DB_NAME=univerra
MONGODB_TIMEOUT_MS=5000
AUTH_SECRET_KEY=changeme
AUTH_TOKEN_MAX_AGE_SECONDS=604800
RATE_LIMIT_AUTH_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW_SECONDS=900
RATE_LIMIT_GRAPH_GENERATE_PER_HOUR=20
RATE_LIMIT_GRAPH_BUILD_PER_HOUR=30
RATE_LIMIT_SIMULATION_CREATE_PER_HOUR=30
RATE_LIMIT_SIMULATION_PREPARE_PER_HOUR=10
RATE_LIMIT_SIMULATION_START_PER_HOUR=20
RATE_LIMIT_REPORT_GENERATE_PER_HOUR=20

# ===== Accelerated LLM Configuration (Optional) =====
# Note: If you do not use the accelerated configuration, remove these entries from your .env file.
LLM_BOOST_API_KEY=changeme
LLM_BOOST_BASE_URL=changeme
LLM_BOOST_MODEL_NAME=changeme
